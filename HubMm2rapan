--// Логика изменения скорости
speedInput.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local numericSpeed = tonumber(speedInput.Text)
        if numericSpeed then
            local character = localPlayer.Character
            if character then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid.WalkSpeed = numericSpeed
                end
            end
        end
    end
end)

--// Логика Infinite Jump
infJumpButton.MouseButton1Click:Connect(function()
    isInfJumpActive = not isInfJumpActive
    if isInfJumpActive then
        infJumpButton.Text = "Бесконечный прыжок: ВКЛ"
        infJumpButton.BackgroundColor3 = Color3.fromRGB(30, 70, 30)
    else
        infJumpButton.Text = "Бесконечный прыжок: ВЫКЛ"
        infJumpButton.BackgroundColor3 = Color3.fromRGB(70, 30, 30)
    end
end)

UserInputService.JumpRequest:Connect(function()
    if isInfJumpActive then
        local character = localPlayer.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end
end)

--// Функция определения ролей и управления ESP подсветкой
local function updateEspHighlights()
    for _, targetPlayer in ipairs(Players:GetPlayers()) do
        if targetPlayer ~= localPlayer and targetPlayer.Character then
            local character = targetPlayer.Character
            local currentHighlight = character:FindFirstChild("DevESP")

            if isEspActive then
                -- Определение роли по наличию оружия или специального объекта Role внутри игрока
                local hasKnife = targetPlayer.Backpack:FindFirstChild("Knife") or character:FindFirstChild("Knife")
                local hasGun = targetPlayer.Backpack:FindFirstChild("Gun") or character:FindFirstChild("Gun")
                local roleValue = targetPlayer:FindFirstChild("Role")

                local isMurderer = hasKnife or (roleValue and roleValue.Value == "Murderer")
                local isSheriff = hasGun or (roleValue and roleValue.Value == "Sheriff")

                if not currentHighlight then
                    currentHighlight = Instance.new("Highlight")
                    currentHighlight.Name = "DevESP"
                    currentHighlight.FillTransparency = 0.4
                    currentHighlight.OutlineTransparency = 0.1
                    currentHighlight.Parent = character
                end

                -- Окрашивание в зависимости от обнаруженной роли
                if isMurderer then
                    currentHighlight.FillColor = Color3.fromRGB(255, 0, 0) -- Красный
                    currentHighlight.OutlineColor = Color3.fromRGB(255, 50, 50)
                elseif isSheriff then
                    currentHighlight.FillColor = Color3.fromRGB(0, 180, 255) -- Голубой
                    currentHighlight.OutlineColor = Color3.fromRGB(50, 200, 255)
                else
                    currentHighlight.FillColor = Color3.fromRGB(255, 255, 255) -- Белый для обычных игроков
                    currentHighlight.OutlineColor = Color3.fromRGB(200, 200, 200)
                end
            else
                if currentHighlight then
                    currentHighlight:Destroy()
                end
            end
        end
    end
end

--// Переключение ESP по клику
espButton.MouseButton1Click:Connect(function()
    isEspActive = not isEspActive
    if isEspActive then
        espButton.Text = "Подсветка ролей (ESP): ВКЛ"
        espButton.BackgroundColor3 = Color3.fromRGB(30, 70, 30)
    else
        espButton.Text = "Подсветка ролей (ESP): ВЫКЛ"
        espButton.BackgroundColor3 = Color3.fromRGB(70, 30, 30)
        updateEspHighlights() -- Вызов для мгновенной очистки эффектов
    end
end)

--// Постоянное обновление ESP для отслеживания перемещений и смены ролей
RunService.Heartbeat:Connect(function()
    if isEspActive then
        updateEspHighlights()
end
end)

