repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

pcall(function() CoreGui:FindFirstChild("GardenTeleport"):Destroy() end)

local savedPosition = nil

local gui = Instance.new("ScreenGui", CoreGui)
gui.Name = "GardenTeleport"
gui.ResetOnSpawn = false

local Main = Instance.new("Frame", gui)
Main.Size = UDim2.new(0, 220, 0, 180)
Main.Position = UDim2.new(0.5, -110, 0.5, -90)
Main.BackgroundColor3 = Color3.fromRGB(46, 46, 46)
Main.BorderSizePixel = 0
Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 16)

local gradient = Instance.new("UIGradient", Main)
gradient.Color = ColorSequence.new(Color3.fromRGB(46, 46, 46), Color3.fromRGB(34, 34, 34))
gradient.Rotation = 180

local stroke = Instance.new("UIStroke", Main)
stroke.Color = Color3.fromRGB(255, 255, 255)
stroke.Transparency = 0.94

local header = Instance.new("Frame", Main)
header.Size = UDim2.new(1, 0, 0, 38)
header.BackgroundTransparency = 1

local title = Instance.new("TextLabel", header)
title.Position = UDim2.new(0, 12, 0, 6)
title.Size = UDim2.new(0, 160, 0, 16)
title.BackgroundTransparency = 1
title.Text = "Grow a Garden 2 | Instant Steal"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.TextSize = 13
title.Font = Enum.Font.GothamBold
title.TextXAlignment = Enum.TextXAlignment.Left

local subtitle = Instance.new("TextLabel", header)
subtitle.Position = UDim2.new(0, 12, 0, 23)
subtitle.Size = UDim2.new(0, 160, 0, 10)
subtitle.BackgroundTransparency = 1
subtitle.Text = "instantly teleport!"
subtitle.TextColor3 = Color3.fromRGB(98, 98, 98)
subtitle.TextSize = 9
subtitle.Font = Enum.Font.GothamMedium
subtitle.TextXAlignment = Enum.TextXAlignment.Left

local closeBtn = Instance.new("TextButton", header)
closeBtn.Position = UDim2.new(1, -34, 0.5, -13)
closeBtn.Size = UDim2.new(0, 26, 0, 26)
closeBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
closeBtn.BorderSizePixel = 0
closeBtn.Text = "X"
closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
closeBtn.TextSize = 13
closeBtn.Font = Enum.Font.GothamBold
closeBtn.AutoButtonColor = false
Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 7)
Instance.new("UIStroke", closeBtn).Color = Color3.fromRGB(255, 255, 255)
closeBtn.MouseButton1Click:Connect(function()
    gui:Destroy()
end)

header.Parent = Main

local content = Instance.new("Frame", Main)
content.Position = UDim2.new(0, 10, 0, 44)
content.Size = UDim2.new(1, -20, 0, 130)
content.BackgroundTransparency = 1

local saveBtn = Instance.new("TextButton", content)
saveBtn.Size = UDim2.new(1, 0, 0, 44)
saveBtn.Position = UDim2.new(0, 0, 0, 0)
saveBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
saveBtn.Text = "SAVE GARDEN"
saveBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
saveBtn.TextSize = 12
saveBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", saveBtn).CornerRadius = UDim.new(0, 12)
Instance.new("UIStroke", saveBtn).Color = Color3.fromRGB(80, 80, 80)

local goBtn = Instance.new("TextButton", content)
goBtn.Size = UDim2.new(1, 0, 0, 44)
goBtn.Position = UDim2.new(0, 0, 0, 54)
goBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
goBtn.Text = "GO TO GARDEN"
goBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
goBtn.TextSize = 12
goBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", goBtn).CornerRadius = UDim.new(0, 12)
Instance.new("UIStroke", goBtn).Color = Color3.fromRGB(80, 80, 80)

local statusLabel = Instance.new("TextLabel", content)
statusLabel.Position = UDim2.new(0, 0, 1, -20)
statusLabel.Size = UDim2.new(1, 0, 0, 16)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "No position saved"
statusLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
statusLabel.TextSize = 9
statusLabel.Font = Enum.Font.GothamMedium

local function getPosition()
    local char = LP.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    return hrp.Position
end

local function savePosition()
    local pos = getPosition()
    if pos then
        savedPosition = pos
        statusLabel.Text = "Saved at: " .. math.floor(pos.X) .. ", " .. math.floor(pos.Y) .. ", " .. math.floor(pos.Z)
        statusLabel.TextColor3 = Color3.fromRGB(100, 200, 100)
    else
        statusLabel.Text = "Cannot save position"
        statusLabel.TextColor3 = Color3.fromRGB(200, 100, 100)
    end
end

local function goToGarden()
    if not savedPosition then
        statusLabel.Text = "No position saved"
        statusLabel.TextColor3 = Color3.fromRGB(200, 150, 50)
        return
    end
    
    local char = LP.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    hrp.CFrame = CFrame.new(savedPosition)
    statusLabel.Text = "Teleported to garden"
    statusLabel.TextColor3 = Color3.fromRGB(100, 200, 200)
    
    task.delay(2, function()
        if statusLabel then
            statusLabel.Text = "Position saved"
            statusLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
        end
    end)
end

saveBtn.MouseButton1Click:Connect(savePosition)
goBtn.MouseButton1Click:Connect(goToGarden)

local dragging = false
local dragStart, startPos
Main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(0, startPos.X.Offset + delta.X, 0, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

task.wait(0.1)

local function fixPosition()
    local char = LP.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local pos = hrp.Position
    if pos.Y < -10 or pos.Y > 1000 or math.abs(pos.X) > 10000 or math.abs(pos.Z) > 10000 then
        hrp.CFrame = CFrame.new(0, 10, 0)
    end
end

fixPosition()

LP.CharacterAdded:Connect(function()
    task.wait(0.5)
    fixPosition()
end)
